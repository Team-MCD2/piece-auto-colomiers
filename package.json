{
  "name": "pieces-auto-colomiers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Site vitrine SARL Pièces Auto Colomiers — pièces auto neuves multi-marques, Mondial Relay, retrait magasin.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:fast": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fonts:install": "node scripts/download-fonts.mjs",
    "assets:brand": "node scripts/process-brand-assets.mjs",
    "assets:brand-logos": "node scripts/fetch-brand-logos.mjs",
    "assets:tiktok": "node scripts/tiktok-download.mjs",
    "assets:images": "node scripts/fetch-images.mjs",
    "assets:all": "npm run fonts:install && npm run assets:brand && npm run assets:brand-logos && npm run assets:images && npm run assets:tiktok",
    "format": "prettier --write \"**/*.{astro,js,jsx,ts,tsx,json,md,css}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.4",
    "@emailjs/browser": "^4.4.1",
    "astro": "^5.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
