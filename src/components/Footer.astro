---
/**
 * Footer — barre inférieure dense, marine bg.
 *
 * Structure (cf. plan.md §3.3) :
 *   Col 1 : Brand (logo + raison sociale + adresse + contact + sociaux)
 *   Col 2 : Pages (FOOTER_NAV.pages)
 *   Col 3 : Top 8 catégories
 *   Col 4 : Horaires + paiements + badges services
 *   Bottom bar : copyright + mentions légales obligatoires (D39)
 *
 * Sociaux (D29, D30, D31, D36, D37) :
 *   - TikTok confirmé → toujours visible
 *   - WhatsApp → visible (D29)
 *   - Instagram / Facebook → conditionnel (null au J0.5 round 3)
 */

import Logo from './Logo.astro';
import { STORE, telUrl, whatsappUrl } from '../data/store.js';
import { FOOTER_NAV, FOOTER_TOP_CATEGORIES } from '../data/menu.js';
import { findCategory } from '../data/categories.js';
import { TIKTOK_PROFILE_URL } from '../data/tiktoks.js';

const topCats = FOOTER_TOP_CATEGORIES
  .map((slug) => findCategory(slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

const year = new Date().getFullYear();
---

<footer class="bg-marine-900 text-offwhite-50 mt-section">
  {/* Diagonal divider */}
  <div class="divider-diagonal opacity-60" aria-hidden="true"></div>

  {/* Trust strip — services badges (au-dessus des cols) */}
  <div class="border-b border-marine-800/80 bg-marine-900">
    <div class="container-tight py-6">
      <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        {STORE.servicesAvail.mondialRelay && (
          <li class="inline-flex items-center gap-2">
            <span class="inline-flex size-7 items-center justify-center rounded-full bg-signal-400 text-marine-900">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/></svg>
            </span>
            <span class="font-semibold">Mondial Relay</span>
          </li>
        )}
        {STORE.servicesAvail.retraitMagasin && (
          <li class="inline-flex items-center gap-2">
            <span class="inline-flex size-7 items-center justify-center rounded-full bg-sky-400 text-marine-900">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            </span>
            <span class="font-semibold">Retrait magasin</span>
          </li>
        )}
        {STORE.servicesAvail.devisRapide && (
          <li class="inline-flex items-center gap-2">
            <span class="inline-flex size-7 items-center justify-center rounded-full bg-signal-400 text-marine-900">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <span class="font-semibold">Devis sous 24 h</span>
          </li>
        )}
        {STORE.servicesAvail.commandeOEM && (
          <li class="inline-flex items-center gap-2">
            <span class="inline-flex size-7 items-center justify-center rounded-full bg-sky-400 text-marine-900">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </span>
            <span class="font-semibold">Commande sur référence OEM</span>
          </li>
        )}
      </ul>
    </div>
  </div>

  {/* === 4 colonnes ======================================================== */}
  <div class="container-tight py-12 lg:py-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-10">

    {/* Col 1 — Brand */}
    <div class="lg:col-span-4 space-y-5">
      <Logo size="lg" variant="light" withText={true} href="/" />
      <p class="text-sm text-offwhite-200 leading-relaxed max-w-prose">
        Vendeur de pièces auto neuves multi-marques à Colomiers. Particuliers et professionnels. Devis sous 24 h, retrait magasin, expédition Mondial Relay.
      </p>
      <address class="not-italic text-sm space-y-2 text-offwhite-200">
        <div class="flex items-start gap-2">
          <svg class="mt-0.5 shrink-0 text-signal-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
          <span>{STORE.adresse.rue}<br/>{STORE.adresse.cp} {STORE.adresse.ville}</span>
        </div>
        <a href={telUrl()} class="flex items-center gap-2 hover:text-white transition-colors">
          <svg class="shrink-0 text-signal-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span class="font-semibold">{STORE.contact.telDisplay}</span>
        </a>
        <a href={`mailto:${STORE.contact.email}`} class="flex items-center gap-2 hover:text-white transition-colors">
          <svg class="shrink-0 text-signal-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span class="break-all">{STORE.contact.email}</span>
          {STORE.contact.emailIsPlaceholder && (
            <span class="text-xs text-signal-400/80 ml-1">(à venir)</span>
          )}
        </a>
      </address>

      {/* Sociaux */}
      <div class="flex items-center gap-2 pt-2">
        <a
          href={TIKTOK_PROFILE_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex size-10 items-center justify-center rounded-full bg-marine-800 hover:bg-signal-400 hover:text-marine-900 transition-colors"
          aria-label="Pièces Auto Colomiers sur TikTok"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.49a8.16 8.16 0 0 0 4.77 1.52V6.55a4.85 4.85 0 0 1-1.84.14z"/></svg>
        </a>
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="inline-flex size-10 items-center justify-center rounded-full bg-marine-800 hover:bg-signal-400 hover:text-marine-900 transition-colors"
          aria-label="Contacter Pièces Auto Colomiers sur WhatsApp"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
        </a>
        {STORE.social.instagram && (
          <a href={STORE.social.instagram} target="_blank" rel="noopener" class="inline-flex size-10 items-center justify-center rounded-full bg-marine-800 hover:bg-signal-400 hover:text-marine-900 transition-colors" aria-label="Pièces Auto Colomiers sur Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
        )}
        {STORE.social.facebook && (
          <a href={STORE.social.facebook} target="_blank" rel="noopener" class="inline-flex size-10 items-center justify-center rounded-full bg-marine-800 hover:bg-signal-400 hover:text-marine-900 transition-colors" aria-label="Pièces Auto Colomiers sur Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
          </a>
        )}
      </div>
    </div>

    {/* Col 2 — Pages */}
    <nav class="lg:col-span-2" aria-label="Liens du site">
      <h3 class="eyebrow-light mb-4">Le site</h3>
      <ul class="space-y-2 text-sm">
        {FOOTER_NAV.pages.map((p) => (
          <li>
            <a href={p.href} class="text-offwhite-200 hover:text-signal-400 transition-colors">
              {p.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* Col 3 — Top catégories */}
    <nav class="lg:col-span-3" aria-label="Catégories populaires">
      <h3 class="eyebrow-light mb-4">Catégories populaires</h3>
      <ul class="grid grid-cols-1 gap-2 text-sm">
        {topCats.map((c) => (
          <li>
            <a href={`/catalogue/${c.slug}`} class="text-offwhite-200 hover:text-signal-400 transition-colors">
              {c.label}
            </a>
          </li>
        ))}
      </ul>
      <a href="/catalogue" class="inline-flex items-center gap-1 mt-4 text-sm text-signal-400 hover:text-signal-300 font-semibold">
        Toutes les catégories
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </nav>

    {/* Col 4 — Horaires + paiements */}
    <div class="lg:col-span-3 space-y-5">
      <div>
        <h3 class="eyebrow-light mb-4">Horaires</h3>
        <ul class="space-y-1.5 text-sm text-offwhite-200">
          {STORE.horaires.map((h) => (
            <li class="flex justify-between gap-3">
              <span class="capitalize">{h.jour}</span>
              <span class="font-medium tabular-nums">
                {h.closed ? (
                  <span class="text-charcoal-300">Fermé</span>
                ) : h.mid ? (
                  <>{h.open}–{h.mid[0]} · {h.mid[1]}–{h.close}</>
                ) : (
                  <>{h.open}–{h.close}</>
                )}
              </span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="eyebrow-light mb-3">Paiements acceptés</h3>
        <p class="text-sm text-offwhite-200">{STORE.paiement.join(' · ')}</p>
      </div>
    </div>
  </div>

  {/* === Bottom bar : mentions légales (D39) =============================== */}
  <div class="border-t border-marine-800 bg-marine-950">
    <div class="container-tight py-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 text-xs text-offwhite-200">
      <p>
        © {year} <span class="font-semibold text-white">{STORE.raisonSociale}</span> · {STORE.formeJuridique} au capital de {STORE.capitalDisplay} · RCS {STORE.rcs} {STORE.sirenDisplay}
      </p>
      <ul class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <li><a href="/mentions-legales" class="hover:text-signal-400 transition-colors">Mentions légales</a></li>
        <li class="opacity-50">·</li>
        <li><a href="/mentions-legales#cookies" class="hover:text-signal-400 transition-colors">Cookies</a></li>
        <li class="opacity-50">·</li>
        <li><a href="/mentions-legales#rgpd" class="hover:text-signal-400 transition-colors">RGPD</a></li>
      </ul>
    </div>
  </div>
</footer>
