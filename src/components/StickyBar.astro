---
/**
 * StickyBar — barre fixée bas mobile uniquement.
 *
 * 3 CTAs equally-spaced :
 *   1) WhatsApp Business
 *   2) Téléphone
 *   3) Devis 24 h (CTA primaire)
 *
 * Cf. plan.md §3.2 et §22 (WhatsApp). Le marquee USP vit dans Header.astro.
 *
 * A11y :
 *   - role="navigation" + aria-label
 *   - icônes décoratives (aria-hidden), texte lisible
 *   - safe-area-inset-bottom pour iPhone notch
 *
 * Layout :
 *   - md:hidden — uniquement mobile/tablette portrait
 *   - body padding-bottom prévu dans globals.css
 */

import { STORE, telUrl, whatsappUrl } from '../data/store.js';

const waUrl = whatsappUrl();
---

<nav
  class="md:hidden fixed inset-x-0 bottom-0 z-30 bg-marine-800 text-white shadow-2xl shadow-marine-900/40 border-t border-marine-700"
  style="padding-bottom: env(safe-area-inset-bottom, 0);"
  aria-label="Actions rapides"
>
  <div class="grid grid-cols-3 divide-x divide-marine-700">
    {/* WhatsApp */}
    <a
      href={waUrl}
      target="_blank"
      rel="noopener"
      class="flex flex-col items-center justify-center gap-0.5 py-3 hover:bg-marine-700 active:bg-marine-900 transition-colors"
      aria-label="Contacter via WhatsApp Business"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/>
      </svg>
      <span class="text-xs font-semibold uppercase tracking-wide">WhatsApp</span>
    </a>

    {/* Tel */}
    <a
      href={telUrl()}
      class="flex flex-col items-center justify-center gap-0.5 py-3 hover:bg-marine-700 active:bg-marine-900 transition-colors"
      aria-label={`Appeler — ${STORE.contact.telDisplay}`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span class="text-xs font-semibold uppercase tracking-wide">Appeler</span>
    </a>

    {/* Devis primary */}
    <a
      href="/contact#devis"
      class="flex flex-col items-center justify-center gap-0.5 py-3 bg-signal-400 text-marine-900 hover:bg-signal-300 active:bg-signal-500 transition-colors"
      aria-label="Demander un devis sous 24 heures"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" x2="8" y1="13" y2="13"/>
        <line x1="16" x2="8" y1="17" y2="17"/>
        <line x1="10" x2="8" y1="9" y2="9"/>
      </svg>
      <span class="text-xs font-bold uppercase tracking-wide">Devis 24 h</span>
    </a>
  </div>
</nav>
