---
/**
 * Notre magasin — page dédiée au point de vente physique de Colomiers.
 *
 * V1 : storefront image + adresse + horaires + paiements + CTA contact.
 * V2 (J4) : map Leaflet interactive + section TikTokGrid.
 *
 * Cf. plan.md §8.
 */

import Layout from '../layouts/Layout.astro';
import StoreMap from '../components/StoreMap.tsx';
import { STORE, telUrl, whatsappUrl } from '../data/store.js';

const breadcrumb = [
  { label: 'Accueil', href: '/' },
  { label: 'Notre magasin' },
];
---

<Layout
  title="Notre magasin à Colomiers — Pièces Auto Colomiers"
  description={`Notre magasin de pièces auto à Colomiers : ${STORE.adresse.full}. Horaires, accès, paiements acceptés. Co-géré par deux entrepreneurs locaux.`}
  breadcrumb={breadcrumb}
>
  {/* Hero avec storefront */}
  <section class="bg-marine-800 text-white relative overflow-hidden">
    <div class="container-tight py-12 lg:py-20 relative grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <nav aria-label="Fil d'Ariane" class="text-sm text-offwhite-200 mb-4">
          <a href="/" class="hover:text-signal-400">Accueil</a>
          <span class="mx-2 opacity-50">›</span>
          <span>Notre magasin</span>
        </nav>
        <span class="eyebrow-light">Au cœur de Toulouse Ouest</span>
        <h1 class="text-h1 lg:text-display-2 mt-2 mb-4">Notre magasin à Colomiers.</h1>
        <p class="text-lg text-offwhite-200 leading-relaxed mb-6">
          {STORE.raisonSociale} est une entreprise familiale créée par deux co-fondateurs entrepreneurs locaux.
          Notre métier : la pièce auto neuve, multi-marques, accessible et bien conseillée.
        </p>
        <p class="text-base text-offwhite-200 leading-relaxed">
          Nous accueillons particuliers et professionnels, du tourisme aux véhicules japonais en passant
          par les utilitaires et les 4×4. Conseil humain, retrait sur place, expédition Mondial Relay.
        </p>
      </div>
      <div class="relative">
        <img
          src="/assets/store/storefront.jpg"
          alt={`Façade du magasin — ${STORE.adresse.full}`}
          class="w-full h-full max-h-[480px] object-cover rounded-card shadow-2xl shadow-marine-950/50"
          loading="eager"
          decoding="async"
          onerror="this.style.display='none';this.parentElement.classList.add('bg-marine-900','aspect-video','flex','items-center','justify-center');this.parentElement.innerHTML='<span class=\'text-offwhite-200\'>Photo magasin à venir</span>'"
        />
      </div>
    </div>
  </section>

  {/* Infos pratiques */}
  <section class="section-y bg-offwhite">
    <div class="container-tight grid lg:grid-cols-3 gap-6">
      {/* Adresse */}
      <article class="card p-6">
        <div class="inline-flex size-12 items-center justify-center rounded-full bg-signal-400 text-marine-900 mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h2 class="font-display uppercase text-h3 mb-3">Adresse</h2>
        <address class="not-italic text-charcoal-700 leading-relaxed mb-4">
          <strong class="text-charcoal-800">{STORE.raisonSociale}</strong><br/>
          {STORE.adresse.rue}<br/>
          {STORE.adresse.cp} {STORE.adresse.ville}<br/>
          {STORE.adresse.region}
        </address>
        <a
          href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(STORE.adresse.full)}`}
          target="_blank"
          rel="noopener"
          class="link-inline text-sm"
        >
          Itinéraire Google Maps →
        </a>
      </article>

      {/* Contact */}
      <article class="card p-6">
        <div class="inline-flex size-12 items-center justify-center rounded-full bg-sky-400 text-marine-900 mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <h2 class="font-display uppercase text-h3 mb-3">Nous contacter</h2>
        <ul class="space-y-3 text-charcoal-700">
          <li>
            <a href={telUrl()} class="link-inline font-semibold text-base">{STORE.contact.telDisplay}</a>
            <span class="block text-xs text-charcoal-500">Lun-Ven 8h30-18h · Sam 9h-13h</span>
          </li>
          <li>
            <a href={whatsappUrl()} target="_blank" rel="noopener" class="link-inline">WhatsApp Business</a>
            <span class="block text-xs text-charcoal-500">Réponse rapide en journée</span>
          </li>
          <li>
            <a href={`mailto:${STORE.contact.email}`} class="link-inline break-all">{STORE.contact.email}</a>
            {STORE.contact.emailIsPlaceholder && <span class="block text-xs text-signal-600">(adresse provisoire — à venir)</span>}
          </li>
        </ul>
      </article>

      {/* Horaires */}
      <article class="card p-6">
        <div class="inline-flex size-12 items-center justify-center rounded-full bg-signal-400 text-marine-900 mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h2 class="font-display uppercase text-h3 mb-3">Horaires</h2>
        <ul class="space-y-1.5 text-sm">
          {STORE.horaires.map((h) => (
            <li class="flex justify-between gap-3">
              <span class="capitalize text-charcoal-700">{h.jour}</span>
              <span class="font-medium text-charcoal-800 tabular-nums">
                {h.closed ? <span class="text-charcoal-400">Fermé</span> :
                  h.mid ? <>{h.open}–{h.mid[0]} · {h.mid[1]}–{h.close}</> :
                  <>{h.open}–{h.close}</>
                }
              </span>
            </li>
          ))}
        </ul>
        <div class="mt-4 pt-4 border-t border-charcoal-100">
          <p class="text-xs text-charcoal-500 mb-1">Paiements acceptés</p>
          <p class="text-sm text-charcoal-700">{STORE.paiement.join(' · ')}</p>
        </div>
      </article>
    </div>
  </section>

  {/* Map interactive */}
  <section class="section-y bg-white border-t border-charcoal-100">
    <div class="container-tight">
      <div class="mb-6 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
        <div class="max-w-2xl">
          <span class="eyebrow">Localisation</span>
          <h2 class="text-h2 mt-2">Comment nous trouver.</h2>
          <p class="text-charcoal-500 mt-2">
            16 allée de l'Adour, à Colomiers. Parking sur place, accès facile depuis la rocade.
          </p>
        </div>
        <a
          href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(STORE.adresse.full)}`}
          target="_blank"
          rel="noopener"
          class="btn-secondary btn-md whitespace-nowrap shrink-0"
        >
          Itinéraire Google Maps →
        </a>
      </div>
      <StoreMap
        client:only="react"
        lat={STORE.coords.lat}
        lng={STORE.coords.lng}
        name={STORE.raisonSociale}
        address={STORE.adresse.full}
        tel={STORE.contact.tel}
        telDisplay={STORE.contact.telDisplay}
        height="480px"
      >
        <div slot="fallback" style="height:480px" class="rounded-card bg-charcoal-50 flex items-center justify-center text-charcoal-400 text-sm">
          Chargement de la carte…
        </div>
      </StoreMap>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-signal-400 text-marine-900">
    <div class="container-tight section-y text-center max-w-2xl">
      <h2 class="text-h2">On vous attend en magasin.</h2>
      <p class="text-lg mt-3 mb-6">
        Pas envie de bouger ? Demandez votre devis en ligne — on revient sous 24 h avec disponibilité, délai et prix.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/contact#devis" class="btn-md bg-marine-800 text-white shadow-lg hover:bg-marine-900">Demander un devis</a>
        <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn-md bg-white/30 text-marine-900 hover:bg-white/50">WhatsApp</a>
      </div>
    </div>
  </section>
</Layout>
