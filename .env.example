# =====================================================================
# Pièces Auto Colomiers — variables d'environnement
# =====================================================================
# Copier ce fichier en `.env` et remplir les valeurs réelles.
# Variables `PUBLIC_*` exposées côté client (ne pas mettre de secrets).
# =====================================================================

# --- Site --------------------------------------------------------------
# URL canonique du site, utilisée pour sitemap, og, JSON-LD canonical.
SITE_URL=https://pieces-auto-colomiers.vercel.app
PUBLIC_SITE_URL=https://pieces-auto-colomiers.vercel.app

# --- EmailJS (formulaire devis — J4) ----------------------------------
# Compte à créer sur https://www.emailjs.com/ par le client (free tier OK).
# Le service relaie les soumissions DevisForm vers l'email du client.
#
# Setup template EmailJS — variables Astro/JS vers le template :
#   {{nom}} {{email}} {{telephone}} {{audience}} {{marque}} {{modele}}
#   {{annee}} {{motorisation}} {{message}} {{photos_count}} {{sent_at}}
#   {{photo_1_data}} {{photo_2_data}} {{photo_3_data}} (data: URLs base64)
# Dans le template HTML, les photos s'affichent via :
#   <img src="{{photo_1_data}}" style="max-width:300px"/>
#
# Sans ces 3 vars : le formulaire fallback en mailto: (UX dégradée mais OK).
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=
# Email de destination (placeholder — à remplacer par contact@piecesauto-colomiers.fr réel)
PUBLIC_EMAILJS_TO_EMAIL=contact@piecesauto-colomiers.fr

# --- Pexels API (build-time, optional pour scripts/fetch-images.mjs) --
# Compte gratuit https://www.pexels.com/api/ — 200 req/h.
# Sans clé : fallback Picsum (placeholders aléatoires, moins propres).
# Lecture par scripts/fetch-images.mjs depuis .env.local en priorité.
PEXELS_API_KEY=

# --- TikTok sync (build-time, optional) -------------------------------
# Compte source pour scripts/tiktok-download.mjs
TIKTOK_USERNAME=pieces.auto.colomiers
TIKTOK_TOP_N=6

# --- Géocodage (build-time, optional) ---------------------------------
# Si vide, on utilise les coords hardcodées dans STORE.coords.
# Sinon, scripts peuvent appeler Nominatim avec ce contact email (politesse OSM).
NOMINATIM_CONTACT_EMAIL=
